{
  "name": "iobroker.pwned-check",
  "version": "0.0.1",
  "description": "Check passwords and emails against breach databases (HIBP, XposedOrNot)",
  "author": {
    "name": "ipod86",
    "email": ""
  },
  "contributors": [],
  "homepage": "https://github.com/ipod86/ioBroker.pwned-check",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "automation",
    "IoT",
    "integration",
    "security"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ipod86/ioBroker.pwned-check.git"
  },
  "engines": {
    "node": ">= 18"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/iobroker": "npm:@iobroker/types@^7.1.0",
    "@types/node": "^22.19.17",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "admin/assets/",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build admin/assets",
    "build": "npm run build:ts && npm run build:react",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "prebuild:react": "rimraf admin/assets",
    "build:react": "npm run --prefix src-admin build",
    "watch:react": "npm run --prefix src-admin start",
    "test:ts": "mocha --config test/mocharc.custom.json src/**/*.test.ts",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "check": "tsc --noEmit",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/ipod86/ioBroker.pwned-check/issues"
  },
  "readmeFilename": "README.md"
}
